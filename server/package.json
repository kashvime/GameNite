{
  "name": "@gamenite/server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "check": "tsc",
    "lint": "eslint .",
    "prettier": "prettier --ignore-path ../.gitignore --check . ",
    "prettier:fix": "prettier --ignore-path ../.gitignore --write .",
    "test": "vitest run --coverage",
    "dev": "nodemon --watch src --exec tsx ./src/server.ts",
    "start": "MODE=production node ./src/server.ts",
    "vitest": "vitest"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@gamenite/shared": "^1.0.0",
    "@keyv/mongo": "^3.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "keyv": "^5.5.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.8.1",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  }
}

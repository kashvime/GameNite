# Copy this file to .env and fill in your values

# Required — used to sign JWTs
JWT_SECRET=your-secret-here

# Database — defaults to in-memory storage (data lost on restart), set MONGO_STR to persist with MongoDB
MONGO_STR=mongodb+srv://user:password@cluster.mongodb.net
MONGO_DB_NAME=GameNite

# Google OAuth — optional, leave blank to disable
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

# URLs — defaults work for local dev, set these in production
CLIENT_URL=http://localhost:4530
